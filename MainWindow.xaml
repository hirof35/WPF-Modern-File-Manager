<Window x:Class="FileManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FileManager"
        mc:Ignorable="d"
        Title="Modern File Manager" Height="600" Width="1000"
        Background="#1E1E1E" Foreground="White">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- ListViewのアイテムスタイル：選択時の色などを調整 -->
        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Style.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#37373D"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#37373D"/>
            </Style.Resources>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- ツールバー -->
            <RowDefinition Height="*"/>
            <!-- メインコンテンツ -->
            <RowDefinition Height="Auto"/>
            <!-- プログレスバー -->
        </Grid.RowDefinitions>

        <!-- ツールバー -->
        <Border Grid.Row="0" Background="#2D2D2D" BorderBrush="#3F3F46" BorderThickness="0,0,0,1" Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <Button Content="" FontFamily="Segoe MDL2 Assets" Width="32" Height="32" 
                            Click="BackButton_Click" x:Name="BackButton" Margin="0,0,4,0" 
                            Background="Transparent" Foreground="White" BorderThickness="0"/>
                    <Button Content="" FontFamily="Segoe MDL2 Assets" Width="32" Height="32" 
                            Click="ForwardButton_Click" x:Name="ForwardButton" Margin="0,0,8,0" 
                            Background="Transparent" Foreground="White" BorderThickness="0"/>
                </StackPanel>

                <TextBlock Text="検索:" VerticalAlignment="Center" Grid.Column="1" Margin="0,0,8,0" Foreground="#AAA"/>
                <TextBox x:Name="SearchTextBox" Grid.Column="2" Width="200" VerticalContentAlignment="Center"
                         TextChanged="SearchTextBox_TextChanged" Background="#3F3F46" Foreground="White" 
                         BorderBrush="#555" Padding="5,0"/>

                <TextBox x:Name="PathTextBox" Grid.Column="3" IsReadOnly="True" Margin="12,0,0,0" 
                         VerticalContentAlignment="Center" Background="#1E1E1E" Foreground="#AAA" 
                         BorderBrush="#3F3F46" Padding="8,0"/>
            </Grid>
        </Border>

        <!-- メインコンテンツ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- ファイル一覧 -->
            <ListView x:Name="FileListView" Grid.Column="0" Background="#1E1E1E" Foreground="#CCC" 
                      BorderThickness="0" SelectionMode="Extended" SelectionChanged="FileListView_SelectionChanged"
                      MouseDoubleClick="FileListView_MouseDoubleClick" VirtualizingPanel.IsVirtualizing="True">
                <ListView.Resources>
                    <Style TargetType="GridViewColumnHeader">
                        <Setter Property="Background" Value="#2D2D2D"/>
                        <Setter Property="Foreground" Value="#AAA"/>
                        <Setter Property="Padding" Value="10,5"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="BorderBrush" Value="#3F3F46"/>
                    </Style>
                </ListView.Resources>

                <ListView.ContextMenu>
                    <ContextMenu Background="#2D2D2D" Foreground="White">
                        <MenuItem Header="名前の変更(_R)" Click="RenameMenuItem_Click"/>
                        <MenuItem Header="デスクトップへコピー(_C)" Click="CopyToDesktop_Click"/>
                        <Separator Background="#3F3F46"/>
                        <MenuItem Header="削除(_D)" Click="DeleteMenuItem_Click" Foreground="#FF6B6B"/>
                    </ContextMenu>
                </ListView.ContextMenu>

                <ListView.View>
                    <GridView>
                        <!-- 名前カラム (リネーム対応) -->
                        <GridViewColumn Width="350">
                            <GridViewColumnHeader Content="名前" Click="SortHeader_Click" Tag="Name"/>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Height="24">
                                        <TextBlock Text="{Binding Icon}" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>

                                        <Grid VerticalAlignment="Center">
                                            <!-- 通常時：表示用テキスト -->
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <!-- 編集時：入力用TextBox -->
                                            <TextBox x:Name="RenameTextBox" Text="{Binding Name, UpdateSourceTrigger=Explicit}"
                                                     KeyDown="RenameTextBox_KeyDown" LostFocus="RenameTextBox_LostFocus"
                                                     Background="#3F3F46" Foreground="White" BorderBrush="#007ACC"
                                                     MinWidth="150" Padding="2,0">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>
                                        </Grid>
                                    </StackPanel>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Width="100">
                            <GridViewColumnHeader Content="サイズ" Click="SortHeader_Click" Tag="SizeBytes"/>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplaySize}" TextAlignment="Right" Width="85" Foreground="#888"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn DisplayMemberBinding="{Binding LastModified, StringFormat={}{0:yyyy/MM/dd HH:mm}}" Width="150">
                            <GridViewColumnHeader Content="更新日" Click="SortHeader_Click" Tag="LastModified"/>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="#121212"/>

            <!-- プレビューパネル -->
            <Border Grid.Column="2" Background="#252526" BorderBrush="#3F3F46" BorderThickness="1,0,0,0">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- タイトル -->
                        <RowDefinition Height="Auto"/>
                        <!-- ファイル名 -->
                        <RowDefinition Height="*"/>
                        <!-- コンテンツ -->
                    </Grid.RowDefinitions>

                    <TextBlock Text="PREVIEW" Grid.Row="0" FontSize="10" FontWeight="Bold" Foreground="#666" Margin="0,0,0,5"/>
                    <TextBlock x:Name="PreviewName" Grid.Row="1" TextWrapping="Wrap" FontSize="14" Foreground="#DDD" Margin="0,0,0,20"/>

                    <Grid Grid.Row="2">
                        <Image x:Name="PreviewImage" Stretch="Uniform" VerticalAlignment="Top"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="PreviewText" TextWrapping="Wrap" FontSize="12" 
                                       Foreground="#AAA" FontFamily="Consolas" LineHeight="18"/>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- 下部プログレスバー -->
        <Border Grid.Row="2" x:Name="ProgressPanel" Visibility="Collapsed" 
                Background="#007ACC" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="ProgressText" Text="コピー中..." Foreground="White" VerticalAlignment="Center" Margin="0,0,15,0"/>
                <ProgressBar x:Name="CopyProgressBar" Grid.Column="1" Height="4" 
                             Background="#40FFFFFF" Foreground="White" BorderThickness="0"/>
            </Grid>
        </Border>
    </Grid>
</Window>
